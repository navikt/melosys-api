<?xml version="1.0" encoding="UTF-8"?>
<!-- Se om nødvendig http://confluence.adeo.no/display/AURA/Logging og http://confluence.adeo.no/display/AURA/Logback -->
<!--TODO Ved bruk av daglige logger (RollingFileAppender) må det angis hvor 
	lenge filer skal tas vare på før de slettes og de skal være komprimert -->
<configuration scan="true" scanPeriod="60 seconds">

    <!-- Driftslogging/error-logg -->
    <appender name="ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <File>${APP_LOG_HOME}/melosys_error.log</File>
        <encoder>
            <pattern>%d [%-5level] [%thread] %logger{5} - [%X{consumerId}, %X{callId}, %X{userId}] - %m%n%rEx</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Daily rollover, gir filnavn med pattern yyyy-MM-dd -->
            <fileNamePattern>${APP_LOG_HOME}/melosys_error.log.%d{yyyy-MM-dd}</fileNamePattern>
            <!-- 30 dager OK? -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Applikasjonslogging -->
    <appender name="APP" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <File>${APP_LOG_HOME}/melosys.log</File>
        <encoder>
            <pattern>%d [%-5level] [%thread] %logger{5} - [%X{consumerId}, %X{callId}, %X{userId}] - %m%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${APP_LOG_HOME}/${APP_LOG_HOME}/melosys.%d{yyyy-MM-dd}</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Sikkerhetslogg -->
    <!--  Pålogging av bruker, endring av tilgang, forsøk å få tilgang etc -->
    <appender name="SIKKERHET" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <File>${APP_LOG_HOME}/melosys_sikkerhet.log</File>
        <encoder>
            <pattern>%d [%-5level] [%thread] %logger{5} - [%X{consumerId}, %X{callId}, %X{userId}] - %m%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${APP_LOG_HOME}/melosys_sikkerhet.log.%d{yyyy-MM-dd}</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>


    <!-- Sporbarhetslogg -->
    <!-- Inneholder informasjon om personer som oppdaterer eller leser sensitiv informasjon. -->
    <appender name="SPORING" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <File>${APP_LOG_HOME}/melosys_sporing.log</File>
        <encoder>
            <pattern>%d [%-5level] [%thread] %logger{5} - [%X{consumerId}, %X{callId}, %X{userId}] - %m%n</pattern>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${APP_LOG_HOME}/melosys_sporing.log.%d{yyyy-MM-dd}</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Syslogappender  -->
    <!-- Syslogappender brukes til å videresende logmeldingene til syslog.
    Dette gjør at loggene kan sentraliseres og behandles i feks Splunk -->
    <!-- Størrelsen på meldingen er begrenset, så det er lurt å begrense exceptions
        og andre ting som kan bli langt. %rEx gir caused by først. Exceptions må
        inkluderes i meldingen for å få det med på samme melding. -->
    <appender name="SYSLOG" class="ch.qos.logback.classic.net.SyslogAppender">

        <syslogHost>localhost</syslogHost>
        <!-- facility er en syslogspesifikk kategoriering. For applikasjonslogger
            skal vi bruke LOCAL1 -->
        <facility>LOCAL1</facility>
        <!-- suffixpattern er formateringen av selve meldingen som sendes til syslog.
            I tillegg så legges det på timestamp, severity og hostnavn. Det første ordet
            i suffixPattern tolkes av rsyslog som programmet som sendte loggmeldingen.
            Denne kan feks være applikasjonsnavnet eller noe annet -->
        <suffixPattern>melosys %mdc %logger{30} %m %n%rEx</suffixPattern>
        <!-- throwableExluded skal alltid være true, ellers kommer stacktrace som
            egne meldinger. -->
        <throwableExcluded>true</throwableExcluded>
    </appender>

    <!-- Logging av tjenestekall, se http://confluence.adeo.no/display/AURA/Logging+av+tjenestekall -->
    <appender name="SERVICE_CALLS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${APP_LOG_HOME}/tjenestekall.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${SERVICE_CALLS_HOME}/tjenestekall.log.%d{yyyy-MM-dd}</fileNamePattern>
            <maxHistory>1</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%date{ISO8601} melosys %level %mdc %m%n%rEx</pattern>
        </encoder>
    </appender>

    <logger name="ServiceCalls" level="INFO" additivity="false">
        <appender-ref ref="SERVICE_CALLS"/>
    </logger>

    <logger name="no.nav" level="${log.level.no.nav:-INFO}"/>

    <!-- Skru på for å logge sql statements med parametere -->
    <logger name="jdbc.sql" level="${log.level.jdbc.sql:-ERROR}"/>

    <logger name="org.hibernate.SQL" level="${log.level.org.hibernate.SQL:-WARN}"/>
    <logger name="com.zaxxer.hikari" level="${log.level.com.zaxxer.hikari:-WARN}"/>
    <logger name="org.hibernate.type" level="${log.level.org.hibernate.type:-WARN}"/>
    <logger name="org.hibernate" level="${log.level.org.hibernate:-WARN}"/>
    <logger name="ch.qos.logback" level="${log.level.ch.qos.logback:-WARN}"/>
    <logger name="org.flywaydb" level="${log.level.org.flywaydb:-INFO}"/>

    <!-- Det er mulig å sette ROOT_LOG_LEVEL deploytime. Hvis dette ikke settes er INFO default -->
    <root level="${ROOT_LOG_LEVEL:-INFO}">
        <appender-ref ref="APP"/>
        <appender-ref ref="ERROR"/>
    </root>
</configuration>
