<?xml version="1.0" encoding="UTF-8"?>
<application xmlns="http://appconfig.aura.nav.no"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://appconfig.aura.nav.no http://maven.adeo.no/xsd/appconfig.xsd ">

    <name>melosys</name>

    <artifacts>
        <ear groupId="no.nav.melosys" artifactId="melosys-ear"/>
    </artifacts>

    <resources>
        <datasource alias="melosysDB" jndi="java:/jdbc/melosysDB" type="ORACLE"/>

        <!--
            Se https://fasit.adeo.no/wicket/bookmarkable/no.nav.aura.envconfig.gui.resources.ResourceDocumentationPage
            (se også detaljer i http://maven.adeo.no/xsd/appconfig.xsd) for hvilke system properties kommer ut av innslagene under:
        -->
        <ldap alias="ldap" mapToProperty="ldap"/>
        <webservice alias="virksomhet:Arbeidsforhold_v3" mapToProperty="Arbeidsforhold_v3"/>
        <webservice alias="virksomhet:Inntekt_v3" mapToProperty="Inntekt_v3"/>
        <webservice alias="virksomhet:Kodeverk_v2" mapToProperty="Kodeverk_v2"/>
        <!--<webservice alias="virksomhet:Medlemskap_v2" mapToProperty="Medlemskap_v2"/>-->
        <webservice alias="virksomhet:Organisasjon_v4" mapToProperty="Organisasjon_v4"/>
        <!--<webservice alias="virksomhet:Person_v3" mapToProperty="Person_v3"/>-->

        <credential alias="srvmelosys" mapToProperty="systembruker"/>

    </resources>

    <serverOptions>
        <memoryParameters resourceAlias="melosys-memparams"/>
        <jvmArgs>-Xloggc:melosys_gc.log -XX:+PrintGCDetails -XX:+PrintGCTimeStamps -XX:+PrintGCDateStamps
            -XX:+UseGCLogFileRotation -XX:GCLogFileSize=50M -XX:NumberOfGCLogFiles=10
        </jvmArgs>
    </serverOptions>

    <security>
        <logins>
            <!-- Vi benytter ikke "no.nav.aura.loginModule.JWTLoginModule", men moduleClass er required-->
            <openIdConnect moduleClass="no.nav.aura.loginModule.JWTLoginModule">
                <contextRoot>/melosys/openid_connect_login</contextRoot>
            </openIdConnect>
        </logins>
    </security>

</application>