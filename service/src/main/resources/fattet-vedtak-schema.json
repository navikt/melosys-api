{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "definitions": {
    "dato": {
      "type": "string",
      "format": "date"
    },
    "dekning": {
      "type": "string",
      "enum": [
        "UTEN_DEKNING",
        "FULL_DEKNING_EOSFO",
        "HELSEDEL",
        "HELSEDEL_MED_SYKE_OG_FORELDREPENGER",
        "PENSJONSDEL",
        "HELSE_OG_PENSJONSDEL",
        "HELSE_OG_PENSJONSDEL_MED_SYKE_OG_FORELDREPENGER",
        "FULL_DEKNING_FTRL"
      ]
    },
    "periode": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "fom": {
          "type": "string",
          "format": "date"
        },
        "tom": {
          "type": "string",
          "format": "date"
        }
      },
      "required": [
        "fom",
        "tom"
      ]
    },
    "trygdeavgift": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "avgiftspliktigInntekt": {
          "type": "integer"
        },
        "avgiftsbeløpMd": {
          "type": "integer"
        },
        "trygdesats": {
          "type": "number"
        },
        "avgiftskode": {
          "type": "string"
        }
      },
      "required": [
        "avgiftspliktigInntekt",
        "avgiftsbeløpMd",
        "trygdesats",
        "avgiftskode"
      ]
    },
    "identifikator": {
      "ident": {
        "type": "string"
      },
      "gjelder": {
        "type": "string",
        "enum": [
          "BRUKER",
          "ORGANISASJON"
        ]
      },
      "required": [
        "ident",
        "gjelder"
      ]
    }
  },
  "required": [
    "sak"
  ],
  "properties": {
    "sak": {
      "type": "object",
      "properties": {
        "fnr": {
          "type": "string"
        },
        "behandlingId": {
          "type": "integer"
        },
        "saksnummer": {
          "type": "string"
        },
        "sakstype": {
          "type": "string",
          "enum": [
            "EU_EOS",
            "TRYGDEAVTALE",
            "FTRL"
          ]
        },
        "registreringsdato": {
          "$ref": "#/definitions/dato"
        }
      },
      "required": [
        "fnr",
        "behandlingId",
        "saksnummer",
        "sakstype",
        "registreringsdato"
      ]
    }
  }
}
