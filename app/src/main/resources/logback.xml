<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="stdout_json" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <fieldNames><version>[ignore]</version></fieldNames>
        </encoder>
    </appender>

    <logger name="no.nav.melosys" level="INFO" additivity="false">
        <appender-ref ref="stdout_json"/>
    </logger>

    <logger name="org.mitre.openid.connect.client.OIDCAuthenticationFilter" level="INFO" additivity="false">
        <appender-ref ref="stdout_json"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="stdout_json"/>
    </root>

    <logger name="org.springframework.oxm.jaxb.Jaxb2Marshaller" level="WARN" additivity="false"/>

</configuration>