<?xml version="1.0" encoding="UTF-8"?>
<included>

    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} | %X{correlation-id} | %logger{10} | %highlight(%level) | %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="auditLogger" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>AUDIT: %d{HH:mm:ss.SSS} | %X{correlation-id} | %logger{10} | %highlight(%level) | %msg%n</pattern>
        </encoder>
    </appender>

    <logger level="INFO" name="auditLogger" additivity="false">
        <appender-ref ref="auditLogger"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="console"/>
    </root>

    <logger name="no.nav.melosys.integrasjon.felles.RestClientLoggingFilter" level="INFO"/>
    <logger name="no.nav.security" level="INFO" />
    <logger name="org.apache.cxf.services" level="WARN"/>
    <logger name="no.nav.melosys.frontendlogg" level="TRACE"/>

    <logger name="no.nav.melosys.integrasjon.doksys.DoksysService" level="DEBUG"/>

    <logger name="org.springframework.orm.jpa" level="WARN" />
    <logger name="org.springframework.transaction" level="WARN" />
    <logger name="org.springframework.transaction.interceptor" level="WARN" />
    <logger name="org.hibernate.SQL" level="WARN" />

    <logger name="org.apache.cxf.ws.addressing.soap.MAPCodec" level="ERROR"/>
    <logger name="org.apache.cxf.ws.addressing.ContextUtils" level="ERROR"/>

    <!-- Sett til debug for å se info om kall til eksterne tjenster -->
    <logger name="reactor.netty.http.client" level="INFO"/>
    <logger name="org.springframework.web.client.RestTemplate" level="INFO"/>
</included>
