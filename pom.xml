    <profiles>
        <profile>
            <id>runSonar</id>
            <activation>
                <activeByDefault>false</activeByDefault>
            </activation>
            <properties>
                <!-- maven.root bør overstyres fra cmdline -->
                <maven.root>${project.basedir}</maven.root>

                <sonar.language/>
                <sonar.core.codeCoveragePlugin>jacoco</sonar.core.codeCoveragePlugin>
                <sonar.dynamicAnalysis>reuseReports</sonar.dynamicAnalysis>
                <sonar.sourceEncoding>UTF-8</sonar.sourceEncoding>
                <sonar.java.source>1.8</sonar.java.source>
                <sonar.sources>.</sonar.sources>
                <sonar.exclusions>
                    **/test/**,**/testutilities/**,**/swagger*,**/coverage/**,**/target/**,**/testdata/**,**/apidoc/**,**/*.spec.jsx,**/_scripts/*,**/test-helpers/**
                </sonar.exclusions>
                <sonar.coverage.exclusions>${sonar.exclusions}</sonar.coverage.exclusions>
                <sonar.java.coveragePlugin>jacoco</sonar.java.coveragePlugin>
                <sonar.jacoco.reportPath>${maven.root}/target/coverage</sonar.jacoco.reportPath>
                <sonar.leak.period>previous_analysis</sonar.leak.period>
            </properties>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

