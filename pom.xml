                    <execution>
                        <id>download-tls-certificate-from-fasit</id>
                        <inherited>false</inherited>
                        <goals>
                            <goal>wget</goal>
                        </goals>
                        <configuration>
                            <url>https://fasit.adeo.no/api/v2/resources/3816108/file/keystore</url>
                            <outputFileName>nav_truststore_nonproduction_ny2.jts</outputFileName>
                        </configuration>
                    </execution>
