        </dependency>

        <!-- DokSys -->
        <dependency>
            <groupId>no.nav.tjenester</groupId>
            <artifactId>nav-dokumentproduksjon-v3-tjenestespesifikasjon</artifactId>
            <classifier>jaxws</classifier>
        </dependency>

